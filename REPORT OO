        verzn  TYPE verzn,
        blart  TYPE bseg-h_blart,
        belnr  TYPE bseg-belnr,
        rebzg  TYPE bseg-rebzg,
        xref2  TYPE bseg-xref2,
        sgtxt  TYPE bseg-sgtxt,
        mensg  TYPE ukm_monitor_message_text,
